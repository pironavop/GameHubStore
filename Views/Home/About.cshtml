@{
    ViewData["Title"] = "About";
}

<div class="container py-5">
    <h1 class="mb-4">About GameHubStore</h1>

    <div class="info-card">
        <p>
            GameHubStore is an ASP.NET Core MVC digital game store project inspired by
            modern gaming marketplaces. It allows users to browse games, add them to cart,
            checkout, simulate payment, and receive digital game keys.
        </p>

        <p>
            The project includes authentication, admin panel, category management,
            platform management, orders, payments, and digital key delivery.
        </p>
    </div>
</div>