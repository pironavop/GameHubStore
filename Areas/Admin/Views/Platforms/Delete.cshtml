@model GameHubStore.Models.Entities.Platform

@{
    ViewData["Title"] = "Delete Platform";
}

<div class="container mt-4">
    <h2>Delete Platform</h2>

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="alert alert-danger">
        Are you sure you want to delete this platform?
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h5>@Model.Name</h5>
            <p class="text-muted">Created: @Model.CreateAt.ToString("dd MMM yyyy")</p>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Platforms" asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">Yes, Delete</button>

        <a asp-area="Admin" asp-controller="Platforms" asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>
    </form>
</div>