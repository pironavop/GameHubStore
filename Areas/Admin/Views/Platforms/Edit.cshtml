@model GameHubStore.Models.Entities.Platform

@{
    ViewData["Title"] = "Edit Platform";
}

<div class="container mt-4">
    <h2>Edit Platform</h2>

    <form asp-area="Admin" asp-controller="Platforms" asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreateAt" />

        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-3">
            <label class="form-label">Platform Name</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Update</button>

        <a asp-area="Admin" asp-controller="Platforms" asp-action="Index" class="btn btn-secondary">
            Back
        </a>
    </form>
</div>