@model GameHubStore.Models.Entities.Category

<h2>Delete Category</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<div class="alert alert-danger">
    Are you sure you want to delete this category?
</div>

<div class="card">
    <div class="card-body">
        <h5>@Model.Name</h5>
        <p>@Model.Description</p>
    </div>
</div>

<form asp-area="Admin" asp-controller="Categories" asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Yes, Delete</button>

    <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>